# Purpose: sudoers policy allowing the app provisioner to create runtime users and control per-user gateway units.
# Before installing, replace:
#   - __APPUSER__  → actual service account (e.g. clawaas)
#   - __PROJECT__  → absolute path to ClawaaS repo (e.g. /opt/ClawaaS)

Defaults!CLAWAAS_CMDS !requiretty

Cmnd_Alias CLAWAAS_CMDS = __PROJECT__/ops/runtime/create_linux_user.sh [0-9a-fA-F]*-[0-9a-fA-F]*-[0-9a-fA-F]*-[0-9a-fA-F]*-[0-9a-fA-F]*, \
    /usr/bin/python3 __PROJECT__/ops/runtime/render_openclaw_config.py *, \
    __PROJECT__/ops/runtime/start_gateway.sh oc_u_*, \
    __PROJECT__/ops/runtime/stop_gateway.sh oc_u_*, \
    __PROJECT__/ops/runtime/bootstrap_agent.sh oc_u_*, \
    __PROJECT__/ops/runtime/delete_agent.sh oc_u_*, \
    __PROJECT__/ops/runtime/inject_container_certs.sh oc_u_*, \
    /usr/bin/chown -R oc_u_*\:oc_u_* /home/oc_u_*/.openclaw, \
    /usr/bin/cat /home/oc_u_*/.openclaw/gateway.env, \
    /usr/bin/journalctl -u openclaw-gateway@oc_u_*.service *, \
    /bin/systemctl start openclaw-gateway@oc_u_*.service, \
    /bin/systemctl stop openclaw-gateway@oc_u_*.service, \
    /bin/systemctl restart openclaw-gateway@oc_u_*.service

__APPUSER__ ALL=(root) NOPASSWD: CLAWAAS_CMDS
