# Backend API base URL that Next.js rewrites /api/* requests to.
# Default in next.config.js is http://127.0.0.1:8000
CLAWAAS_API_BASE_URL=http://127.0.0.1:8000

# Comma-separated list of allowed origins.
# In web(next.config.js), this is used for Next.js allowedDevOrigins.
# You can reuse the same value in API CORS settings for non-dev/prod policies.
# Example:
# CLAWAAS_CORS_ALLOWED_ORIGINS=http://10.166.252.159:3000,http://localhost:3000
CLAWAAS_CORS_ALLOWED_ORIGINS=
